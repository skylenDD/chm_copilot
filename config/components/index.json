{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "低代码平台内置组件配置",
    "type": "object",
    "properties": {
        "components": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "组件唯一标识"
                    },
                    "name": {
                        "type": "string",
                        "description": "组件名称"
                    },
                    "category": {
                        "type": "string",
                        "description": "组件分类，如表单、布局、图表"
                    },
                    "icon": {
                        "type": "string",
                        "description": "组件图标（可选）"
                    },
                    "props": {
                        "type": "object",
                        "description": "组件可配置属性",
                        "additionalProperties": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "string",
                                        "number",
                                        "boolean",
                                        "select",
                                        "object",
                                        "array"
                                    ]
                                },
                                "label": {
                                    "type": "string"
                                },
                                "default": {},
                                "required": {
                                    "type": "boolean"
                                },
                                "options": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "label": {
                                                "type": "string"
                                            },
                                            "value": {}
                                        },
                                        "required": [
                                            "label",
                                            "value"
                                        ]
                                    }
                                }
                            },
                            "required": [
                                "type",
                                "label"
                            ]
                        }
                    },
                    "events": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "description": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "name"
                            ]
                        }
                    }
                },
                "required": [
                    "id",
                    "name",
                    "category"
                ]
            }
        }
    },
    "required": [
        "components"
    ],
    "examples": [
        {
            "components": [
                {
                    "id": "fh_input-text",
                    "name": "文本输入框",
                    "category": "form",
                    "icon": "icon-text",
                    "props": {
                        "label": {
                            "type": "string",
                            "label": "标签",
                            "default": "请输入"
                        },
                        "placeholder": {
                            "type": "string",
                            "label": "占位符",
                            "default": "请输入内容"
                        },
                        "required": {
                            "type": "boolean",
                            "label": "是否必填",
                            "default": false
                        }
                    },
                    "events": [
                        {
                            "name": "onChange",
                            "description": "内容变化事件"
                        },
                        {
                            "name": "onFocus",
                            "description": "获取焦点事件"
                        }
                    ]
                },
                {
                    "id": "fh_select",
                    "name": "下拉框",
                    "category": "form",
                    "icon": "icon-select",
                    "props": {
                        "label": {
                            "type": "string",
                            "label": "标签",
                            "default": "选择项"
                        },
                        "options": {
                            "type": "array",
                            "label": "选项列表",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "label": {
                                        "type": "string"
                                    },
                                    "value": {}
                                },
                                "required": [
                                    "label",
                                    "value"
                                ]
                            }
                        },
                        "required": {
                            "type": "boolean",
                            "label": "是否必选",
                            "default": false
                        }
                    },
                    "events": [
                        {
                            "name": "onChange",
                            "description": "选择变化事件"
                        }
                    ]
                },
                {
                    "id": "fh_date-picker",
                    "name": "日期选择器",
                    "category": "form",
                    "icon": "icon-calendar",
                    "props": {
                        "label": {
                            "type": "string",
                            "label": "标签",
                            "default": "选择日期"
                        },
                        "format": {
                            "type": "string",
                            "label": "日期格式",
                            "default": "YYYY-MM-DD"
                        }
                    },
                    "events": [
                        {
                            "name": "onChange",
                            "description": "日期变化事件"
                        }
                    ]
                },
                {
                    "id": "fh_table",
                    "name": "表格",
                    "category": "data",
                    "icon": "icon-table",
                    "props": {
                        "columns": {
                            "type": "array",
                            "label": "列配置",
                            "items": {
                                "type": "object"
                            }
                        },
                        "data": {
                            "type": "array",
                            "label": "数据源",
                            "items": {
                                "type": "object"
                            }
                        }
                    },
                    "events": [
                        {
                            "name": "onRowClick",
                            "description": "行点击事件"
                        }
                    ]
                },
                {
                    "id": "fh_modal",
                    "name": "弹窗",
                    "category": "feedback",
                    "icon": "icon-modal",
                    "props": {
                        "title": {
                            "type": "string",
                            "label": "标题",
                            "default": "弹窗标题"
                        },
                        "visible": {
                            "type": "boolean",
                            "label": "显示状态",
                            "default": false
                        }
                    },
                    "events": [
                        {
                            "name": "onClose",
                            "description": "关闭事件"
                        },
                        {
                            "name": "onOpen",
                            "description": "打开事件"
                        }
                    ]
                },
                {
                    "id": "fh_text",
                    "name": "文本",
                    "category": "basic",
                    "icon": "icon-text",
                    "props": {
                        "content": {
                            "type": "string",
                            "label": "文本内容",
                            "default": "示例文本"
                        }
                    },
                    "events": []
                },
                {
                    "id": "fh_form",
                    "name": "表单",
                    "category": "form",
                    "icon": "icon-form",
                    "props": {
                        "fields": {
                            "type": "array",
                            "label": "字段列表",
                            "items": {
                                "type": "object"
                            }
                        },
                        "submitText": {
                            "type": "string",
                            "label": "提交文本",
                            "default": "提交"
                        }
                    },
                    "events": [
                        {
                            "name": "onSubmit",
                            "description": "提交事件"
                        }
                    ]
                },
                {
                    "id": "fh_button",
                    "name": "按钮",
                    "category": "basic",
                    "icon": "icon-button",
                    "props": {
                        "text": {
                            "type": "string",
                            "label": "按钮文本",
                            "default": "点击"
                        },
                        "type": {
                            "type": "string",
                            "label": "样式类型",
                            "default": "primary",
                            "options": [
                                {
                                    "label": "默认",
                                    "value": "default"
                                },
                                {
                                    "label": "主按钮",
                                    "value": "primary"
                                }
                            ]
                        }
                    },
                    "events": [
                        {
                            "name": "onClick",
                            "description": "点击事件"
                        }
                    ]
                },
                {
                    "id": "fh_radio",
                    "name": "单选",
                    "category": "form",
                    "icon": "icon-radio",
                    "props": {
                        "label": {
                            "type": "string",
                            "label": "标签",
                            "default": "单选"
                        },
                        "options": {
                            "type": "array",
                            "label": "选项列表",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "label": {
                                        "type": "string"
                                    },
                                    "value": {}
                                },
                                "required": [
                                    "label",
                                    "value"
                                ]
                            }
                        }
                    },
                    "events": [
                        {
                            "name": "onChange",
                            "description": "选项变化"
                        }
                    ]
                },
                {
                    "id": "fh_checkbox",
                    "name": "复选",
                    "category": "form",
                    "icon": "icon-checkbox",
                    "props": {
                        "label": {
                            "type": "string",
                            "label": "标签",
                            "default": "复选"
                        },
                        "options": {
                            "type": "array",
                            "label": "选项列表",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "label": {
                                        "type": "string"
                                    },
                                    "value": {}
                                },
                                "required": [
                                    "label",
                                    "value"
                                ]
                            }
                        }
                    },
                    "events": [
                        {
                            "name": "onChange",
                            "description": "选择变化"
                        }
                    ]
                }
            ]
        }
    ]
}